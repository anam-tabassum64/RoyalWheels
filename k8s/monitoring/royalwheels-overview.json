{
  "uid": "royalwheels-overview",
  "title": "RoyalWheels Overview",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Prometheus Up",
      "id": 1,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(up)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Rate (5m)",
      "id": 2,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(django_http_requests_before_middlewares_total[5m])",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 12,
        "h": 6
      }
    },
    {
      "type": "timeseries",
      "title": "Process CPU (rate 5m)",
      "id": 3,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(process_cpu_seconds_total[5m])",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 9,
        "h": 6
      }
    },
    {
      "type": "timeseries",
      "title": "Process Resident Memory (bytes)",
      "id": 4,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_resident_memory_bytes",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 9,
        "y": 4,
        "w": 9,
        "h": 6
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Volume (5m)",
      "id": 5,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(django_http_requests_before_middlewares_total[5m])",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 9,
        "h": 6
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Request Latency p95 (s)",
      "id": 6,
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(django_http_requests_latency_including_middlewares_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 9,
        "y": 10,
        "w": 9,
        "h": 6
      }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "refresh": "30s"
}
